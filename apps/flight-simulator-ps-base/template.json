{
  "id": "demo-flight-simulator-v2",
  "version": "2.0.0",
  "buildConfig": {
    "required": true,
    "type": "bundled",
    "command": "npm run build",
    "publishSource": "dist"
  },
  "upstream": {
    "sourceType": "internal",
    "sourceRoot": "template-sources/flight-simulator/app"
  },
  "capabilities": ["auth", "leaderboard", "publish", "ps_asset"],
  "buildConfig": {
    "required": true,
    "command": "npm run build",
    "outputDir": "dist",
    "publishSource": "dist",
    "entryHtml": "index.html"
  },
  "immutablePaths": [
    ".gitignore",
    "package.json",
    "vite.config.js",
    "js/viverseAuth.js",
    "js/viverseLeaderboard.js",
    "src/core/EventBus.js",
    "src/core/GameState.js"
  ],
  "editablePaths": [
    "index.html",
    ".env",
    "js/viverseConfig.js",
    "src/main.js",
    "src/core/Constants.js",
    "src/core/Game.js",
    "src/gameplay/**",
    "src/level/**",
    "src/systems/**",
    "src/audio/**",
    "src/ui/**",
    "src/components/**",
    "public/**"
  ],
  "injectionHooks": [
    {
      "hookId": "auth-bootstrap",
      "file": "js/viverseAuth.js",
      "functionOrRegion": "ViverseAuthController.initialize/checkAuth",
      "purpose": "VIVERSE auth bootstrap with iframe handshake delay and resilient profile recovery",
      "required": true
    },
    {
      "hookId": "leaderboard-client",
      "file": "js/viverseLeaderboard.js",
      "functionOrRegion": "ViverseLeaderboardController.initialize/submitScore",
      "purpose": "gameDashboard leaderboard submit/fetch flow with idempotent guard",
      "required": true
    },
    {
      "hookId": "game-loop",
      "file": "src/core/Game.js",
      "functionOrRegion": "Game.startGame/animate/onCrash",
      "purpose": "Three.js render loop, player update, ring collection, crash detection",
      "required": true
    },
    {
      "hookId": "flight-physics",
      "file": "src/gameplay/Player.js",
      "functionOrRegion": "Player.update/buildAircraft",
      "purpose": "Aircraft pitch/roll/yaw physics, altitude clamping, crash trigger",
      "required": true
    },
    {
      "hookId": "ps-aircraft-swap",
      "file": "index.html",
      "functionOrRegion": "window.__FLIGHT_SIM_CONFIG__.aircraftUrl",
      "purpose": "Set aircraftUrl to a .xrg URL from stream.viverse.com/console to replace the procedural aircraft with a Polygon Streaming model. Tune aircraftOffset, aircraftRotationDeg, and aircraftScale so arbitrary assets like robots can be swapped into the player slot.",
      "required": false
    },
    {
      "hookId": "environment-asset-swap",
      "file": "index.html",
      "functionOrRegion": "window.__FLIGHT_SIM_CONFIG__.environmentConfig",
      "purpose": "Swap or retheme world modules such as ground, fog, mountains, trees, clouds, lighting, and sky texture/gradient without changing gameplay code.",
      "required": false
    }
  ],
  "requiredGates": ["build.app_id_propagation"],
  "compliancePaths": {
    "authFiles": [
      "js/viverseAuth.js",
      "js/viverseConfig.js"
    ],
    "startupFiles": [
      "index.html",
      "src/main.js"
    ]
  },
  "appIdPropagation": {
    "strategy": "runtime-config-or-hostname",
    "approvedConfigFiles": [
      "index.html"
    ]
  },
  "authPreflightMode": "verify_only",
  "rulesetSchemaRef": "./scenario.schema.json#/definitions/rulesetRef",
  "scenarioSchemaRef": "./scenario.schema.json",
  "enforcement": {
    "defaultMode": "enforce"
  }
}
