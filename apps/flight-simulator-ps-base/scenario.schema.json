{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "demo-flight-simulator-v2 scenario",
  "type": "object",
  "required": ["templateId", "rulesetId"],
  "properties": {
    "templateId": { "type": "string", "const": "demo-flight-simulator-v2" },
    "rulesetId": { "$ref": "#/definitions/rulesetRef" },
    "environment": {
      "type": "string",
      "enum": ["day", "dusk", "night", "arctic"],
      "default": "dusk"
    },
    "difficulty": {
      "type": "number",
      "minimum": 1,
      "maximum": 10,
      "default": 5
    },
    "ringCount": {
      "type": "number",
      "minimum": 5,
      "maximum": 50,
      "default": 15
    },
    "customAssets": {
      "type": "object",
      "properties": {
        "aircraft": { "type": "string" },
        "terrain": { "type": "string" }
      },
      "additionalProperties": true
    }
  },
  "definitions": {
    "rulesetRef": {
      "type": "string",
      "enum": ["default"]
    }
  },
  "additionalProperties": true
}
